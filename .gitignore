# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Local download cache for data-raw/make_benchmark_data.R (raw bayesTLS source
# files; safe to delete, never committed)
data-raw/.cache/

# Simulation outputs (regenerated by scripts/simulations/run_simulations.R; can
# be large and machine-specific, so never committed)
/output/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site (built to pkgdown-site/ so it does not collide with the tracked
# docs/ governance tree of design notes, dev-log, and the agent-kit)
pkgdown-site/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Compiled C/C++ / TMB objects and shared libraries (rebuilt locally per platform)
src/*.o
src/*.so
src/*.dll
*.o
*.so
*.dll

# Local, machine-specific Claude Code settings
.claude/settings.local.json
